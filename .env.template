# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must never be committed.

# ───────────────────────────────────────────────────────────────────────────
# Azure AI Foundry
# ───────────────────────────────────────────────────────────────────────────
# Found in your Foundry project → Settings → Project details
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1

# ───────────────────────────────────────────────────────────────────────────
# Azure ML Managed Online Endpoint
# ───────────────────────────────────────────────────────────────────────────
# Set after running azure_ml/deploy.py
ML_ENDPOINT_URL=https://<endpoint-name>.<region>.inference.ml.azure.com/score
ML_AUTH_MODE=aad
# Optional: override only if your endpoint requires a different audience
ML_AAD_SCOPE=https://ml.azure.com/.default

# ───────────────────────────────────────────────────────────────────────────
# Azure ML Workspace (used by training + deploy scripts)
# ───────────────────────────────────────────────────────────────────────────
AZURE_ML_SUBSCRIPTION_ID=<your-subscription-id-guid>
AZURE_ML_RESOURCE_GROUP=<your-resource-group>
AZURE_ML_WORKSPACE_NAME=<your-aml-workspace>
AZURE_ML_COMPUTE_NAME=<your-compute-cluster-name>
